{
  "name": "plexus-agent-config",
  "version": "0.0.6",
  "description": "Local dashboard to sync Claude Code, Cursor, Codex, Gemini CLI, and Qwen Code rules, MCP servers, and skills.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://minilv.github.io/Plexus/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miniLV/Plexus.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/miniLV/Plexus/issues"
  },
  "keywords": [
    "ai-agents",
    "ai-coding-tools",
    "agent-config",
    "agent-configuration",
    "claude-code",
    "codex",
    "config-sync",
    "cursor",
    "local-first",
    "mcp",
    "model-context-protocol",
    "skills"
  ],
  "bin": {
    "plexus": "dist/bin.js"
  },
  "main": "dist/bin.js",
  "files": ["dist/**/*", "package.json"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "npm run build && node ../../scripts/bundle-npm-deps.mjs",
    "postpack": "node ../../scripts/bundle-npm-deps.mjs --clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kleur": "^4.1.5",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.4.2",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "plexus-agent-config-core": "0.0.6",
    "plexus-agent-config-web": "0.0.6",
    "typescript": "^5.4.5"
  }
}
