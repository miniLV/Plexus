{
  "name": "plexus-agent-config",
  "version": "0.0.1",
  "description": "Plexus CLI: launches the dashboard and exposes core commands.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/miniLV/Plexus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miniLV/Plexus.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/miniLV/Plexus/issues"
  },
  "keywords": ["ai-agents", "claude-code", "codex", "cursor", "mcp", "model-context-protocol"],
  "bin": {
    "plexus": "dist/bin.js"
  },
  "main": "dist/bin.js",
  "files": ["dist/**/*", "package.json"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "kleur": "^4.1.5",
    "plexus-agent-config-core": "0.0.1",
    "plexus-agent-config-web": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
