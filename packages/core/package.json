{
  "name": "plexus-agent-config-core",
  "version": "0.0.6",
  "description": "Core library for syncing AI agent rules, MCP servers, and skills across Claude Code, Cursor, Codex, Gemini CLI, and Qwen Code.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://minilv.github.io/Plexus/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miniLV/Plexus.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/miniLV/Plexus/issues"
  },
  "keywords": [
    "ai-agents",
    "ai-coding-tools",
    "agent-config",
    "agent-configuration",
    "claude-code",
    "codex",
    "config-sync",
    "cursor",
    "local-first",
    "mcp",
    "model-context-protocol",
    "skills"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/**/*", "package.json"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "yaml": "^2.4.2",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
