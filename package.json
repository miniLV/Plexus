{
  "name": "plexus-monorepo",
  "private": true,
  "version": "0.0.7",
  "description": "Team-shared AI agent config: one source of truth for MCP servers and skills across Claude Code, Cursor, Codex, and Factory Droid.",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w @plexus/core",
    "build:cli": "npm run build -w @plexus/cli",
    "dev": "npm run dev -w @plexus/web",
    "start": "node packages/cli/dist/bin.js",
    "link": "npm run build && cd packages/cli && npm link",
    "unlink": "cd packages/cli && npm unlink -g",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test -w @plexus/core",
    "verify": "npm run check && npm run test:core && npm run build",
    "bump": "node scripts/bump.mjs",
    "bump:patch": "node scripts/bump.mjs",
    "bump:dry": "node scripts/bump.mjs --dry",
    "release:patch": "npm run verify && npm run bump:patch && node scripts/release-commit.mjs",
    "ship": "node scripts/ship.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.17"
  }
}
